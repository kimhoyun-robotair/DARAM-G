<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ramgbot">
    <!-- Include 공용 매크로 -->
    <xacro:include filename="$(find daramg_sim)/urdf/inertial_macros.xacro"/>
    <xacro:include filename="$(find daramg_sim)/urdf/materials.xacro"/>
    <xacro:include filename="$(find daramg_sim)/urdf/ramgbot.gazebo"/>
    <xacro:include filename="$(find daramg_sim)/urdf/diff_drive.gazebo"/>
    <xacro:include filename="$(find daramg_sim)/urdf/forwardCam.xacro"/>

    <!-- 기준 프레임 -->
    <link name="base_footprint"/>

    <!-- base_footprint -> chassis (고정) -->
    <joint name="chassis_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="base_footprint"/>
        <child link="chassis"/>
    </joint>

    <link name="chassis">
        <visual>
            <geometry>
                <box size="0.2 0.2 0.14"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.2 0.2 0.14"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="3.0" x="0.2" y="0.2" z="0.14">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <xacro:mount_rgbd_front parent="chassis"
                            prefix="bbox_front"
                            x="0.11" y="0.0" z="0.12"
                            pitch_deg="20"
                            width="1080" height="720"
                            topic="camera"/>

    <link name="front_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </collision>
        <xacro:inertial_cylinder mass="0.5" radius="0.05" length="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="front_left_wheel"/>
        <origin xyz="0.1 0.1 -0.12" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Front Right Wheel -->
    <link name="front_right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </collision>
        <xacro:inertial_cylinder mass="0.5" radius="0.05" length="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <joint name="front_right_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="front_right_wheel"/>
        <origin xyz="0.1 -0.1 -0.12" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Rear Left Wheel -->
    <link name="rear_left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </collision>
        <xacro:inertial_cylinder mass="0.5" radius="0.05" length="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <joint name="rear_left_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="rear_left_wheel"/>
        <origin xyz="-0.1 0.1 -0.12" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Rear Right Wheel -->
    <link name="rear_right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </collision>
        <xacro:inertial_cylinder mass="0.5" radius="0.05" length="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <joint name="rear_right_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="rear_right_wheel"/>
        <origin xyz="-0.1 -0.1 -0.12" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

</robot>